<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>About QuizSphere</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/header.css">
    <link rel="stylesheet" href="/css/footer.css">
    <link rel="stylesheet" href="/css/about.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>

<%- include('partials/header') %>

<main class="about-main">
    <div class="about-container">

        <!-- HERO SECTION -->
        <section class="about-hero">
            <div class="hero-content">
                <i class="fas fa-brain hero-icon"></i>
                <h1>About QuizSphere</h1>
                <p class="hero-subtitle">
                    A modern platform designed to help students test their knowledge, 
                    track progress, and improve learning through interactive quizzes.
                </p>
            </div>
            <div class="hero-pattern"></div>
        </section>

        <!-- PLATFORM DESCRIPTION -->
        <section class="about-section description-section">
            <div class="section-header">
                <h2>What is QuizSphere?</h2>
                <div class="header-underline"></div>
            </div>
            <div class="description-content">
                <p>
                    QuizSphere is an interactive quiz platform designed to help students and learners 
                    practice and improve their knowledge in different subjects. The platform provides 
                    structured quizzes, performance analytics, and instant feedback to help users 
                    identify their strengths and weaknesses.
                </p>
                <p>
                    Whether you're preparing for exams, learning a new subject, or just want to test 
                    your knowledge, QuizSphere offers a comprehensive solution with a user-friendly 
                    interface and detailed performance tracking.
                </p>
            </div>
        </section>

        <!-- FEATURES SECTION -->
        <section class="about-section features-section">
            <div class="section-header">
                <h2>Key Features</h2>
                <div class="header-underline"></div>
            </div>

            <div class="feature-grid">
                <!-- Feature 1 -->
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-question-circle"></i>
                    </div>
                    <h3>Interactive Quizzes</h3>
                    <p>Take quizzes across multiple subjects and test your knowledge instantly with our engaging interface.</p>
                </div>

                <!-- Feature 2 -->
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-chart-line"></i>
                    </div>
                    <h3>Performance Analytics</h3>
                    <p>View detailed insights about your quiz results and track your learning progress over time.</p>
                </div>

                <!-- Feature 3 -->
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-bolt"></i>
                    </div>
                    <h3>Instant Results</h3>
                    <p>Get immediate feedback after completing quizzes along with performance breakdown and analysis.</p>
                </div>

                <!-- Feature 4 -->
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-check-circle"></i>
                    </div>
                    <h3>Answer Review</h3>
                    <p>Review your answers after completing a quiz and learn from mistakes with detailed explanations.</p>
                </div>

                <!-- Feature 5 -->
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-trophy"></i>
                    </div>
                    <h3>Progress Tracking</h3>
                    <p>Track your quiz attempts, scores, and achievements over time to measure improvement.</p>
                </div>

                <!-- Feature 6 -->
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-user-graduate"></i>
                    </div>
                    <h3>User Profiles</h3>
                    <p>Manage your profile, statistics, and learning journey with personalized dashboards.</p>
                </div>
            </div>
        </section>

        <!-- HOW IT WORKS SECTION -->
        <section class="about-section how-it-works">
            <div class="section-header">
                <h2>How It Works</h2>
                <div class="header-underline"></div>
            </div>

            <div class="steps-container">
                <!-- Step 1 -->
                <div class="step">
                    <div class="step-number">1</div>
                    <div class="step-icon">
                        <i class="fas fa-user-plus"></i>
                    </div>
                    <div class="step-content">
                        <h3>Sign Up</h3>
                        <p>Create an account and log into the platform to start your learning journey.</p>
                    </div>
                </div>

                <!-- Step 2 -->
                <div class="step">
                    <div class="step-number">2</div>
                    <div class="step-icon">
                        <i class="fas fa-pencil-alt"></i>
                    </div>
                    <div class="step-content">
                        <h3>Take Quizzes</h3>
                        <p>Select a subject and start attempting quizzes at your own pace.</p>
                    </div>
                </div>

                <!-- Step 3 -->
                <div class="step">
                    <div class="step-number">3</div>
                    <div class="step-icon">
                        <i class="fas fa-chart-bar"></i>
                    </div>
                    <div class="step-content">
                        <h3>Analyze Results</h3>
                        <p>Review answers, track performance, and improve your knowledge.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- MISSION SECTION -->
        <section class="about-section mission-section">
            <div class="mission-card">
                <i class="fas fa-bullseye mission-icon"></i>
                <h2>Our Mission</h2>
                <p>
                    QuizSphere aims to make learning interactive, accessible, and data-driven. 
                    By combining engaging quizzes with performance insights, we help learners 
                    build stronger knowledge and confidence in their chosen subjects.
                </p>
                <div class="mission-stats">
                    <div class="stat">
                        <span class="stat-number">15+</span>
                        <span class="stat-label">Quizzes</span>
                    </div>
                    <div class="stat">
                        <span class="stat-number">3</span>
                        <span class="stat-label">Subjects</span>
                    </div>
                    <div class="stat">
                        <span class="stat-number">150+</span>
                        <span class="stat-label">Questions</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA SECTION -->
        <section class="cta-section">
            <div class="cta-content">
                <h2>Ready to test your knowledge?</h2>
                <p>Join QuizSphere today and start your learning journey!</p>
                <div class="cta-buttons">
                    <a href="/quiz" class="btn btn-primary cta-btn">
                        <i class="fas fa-play"></i> Start Quiz
                    </a>
                    <a href="/dashboard" class="btn btn-secondary cta-btn">
                        <i class="fas fa-tachometer-alt"></i> Go to Dashboard
                    </a>
                </div>
            </div>
        </section>

    </div>
</main>

<%- include('partials/footer') %>

</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | QuizSphere</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/auth.css">
</head>
<body>
    <!-- Simple Quiz Background -->
    <div class="quiz-bg" style="background: #7BA7F2; opacity: 0.15;"></div>
    
    <div class="auth-wrapper">
        <div class="auth-card">
            <!-- Compact Header -->
            <div class="auth-header">
                <div class="auth-icon">
                    <i class="fas fa-user-graduate" style="color: #7BA7F2; font-size: 40px;"></i>
                </div>
                <h1 class="auth-title" style="color: #2C3E50;">Create Account</h1>
                <p class="auth-subtitle" style="color: #7BA7F2;">Join QuizSphere today</p>
            </div>

            <!-- Error Message -->
            <% if (locals.error) { %>
                <div class="error-message">
                    <span class="error-icon">!</span>
                    <span><%= error %></span>
                </div>
            <% } %>

            <!-- Compact Form -->
            <form action="/signup" method="POST" class="auth-form">
                <div class="form-row">
                    <div class="form-group">
                        <label for="name" class="form-label" style="color: #2C3E50;">
                            <i class="fas fa-user" style="color: #7BA7F2;"></i> Full Name
                        </label>
                        <input 
                            type="text" 
                            id="name" 
                            name="name" 
                            class="form-input"
                            value="<%= locals.formData && formData.name ? formData.name : '' %>"
                            placeholder="John Doe"
                            required
                            style="border-color: #e2e8f0;"
                        >
                    </div>

                    <div class="form-group">
                        <label for="rollNumber" class="form-label" style="color: #2C3E50;">
                            <i class="fas fa-id-card" style="color: #7BA7F2;"></i> Roll No.
                        </label>
                        <input 
                            type="text" 
                            id="rollNumber" 
                            name="rollNumber" 
                            class="form-input"
                            value="<%= locals.formData && formData.rollNumber ? formData.rollNumber : '' %>"
                            placeholder="2024CS001"
                            required
                            style="border-color: #e2e8f0;"
                        >
                    </div>
                </div>

                <div class="form-group">
                    <label for="email" class="form-label" style="color: #2C3E50;">
                        <i class="fas fa-envelope" style="color: #7BA7F2;"></i> Email
                    </label>
                    <input 
                        type="email" 
                        id="email" 
                        name="email" 
                        class="form-input"
                        value="<%= locals.formData && formData.email ? formData.email : '' %>"
                        placeholder="student@university.edu"
                        required
                        style="border-color: #e2e8f0;"
                    >
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="password" class="form-label" style="color: #2C3E50;">
                            <i class="fas fa-lock" style="color: #7BA7F2;"></i> Password
                        </label>
                        <div class="password-field">
                            <input 
                                type="password" 
                                id="password" 
                                name="password" 
                                class="form-input password-input"
                                placeholder="Min. 3 characters"
                                required
                                style="border-color: #e2e8f0;"
                            >
                            <button 
                                type="button" 
                                class="password-toggle" 
                                onclick="togglePassword('password', this)"
                                aria-label="Toggle password visibility"
                            >
                                <i class="far fa-eye"></i>
                            </button>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="confirmPassword" class="form-label" style="color: #2C3E50;">
                            <i class="fas fa-lock" style="color: #7BA7F2;"></i> Confirm
                        </label>
                        <div class="password-field">
                            <input 
                                type="password" 
                                id="confirmPassword" 
                                name="confirmPassword" 
                                class="form-input password-input"
                                placeholder="Re-enter password"
                                required
                                style="border-color: #e2e8f0;"
                            >
                            <button 
                                type="button" 
                                class="password-toggle" 
                                onclick="togglePassword('confirmPassword', this)"
                                aria-label="Toggle password visibility"
                            >
                                <i class="far fa-eye"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Simple Terms -->
                <div class="terms-row">
                    <input type="checkbox" id="terms" name="terms" required style="accent-color: #7BA7F2;">
                    <label for="terms" style="color: #5a6e84;">I accept <a href="#" style="color: #7BA7F2;">Terms & Conditions</a></label>
                </div>

                <!-- Submit Button -->
                <button type="submit" class="btn btn-primary btn-block" style="background: #7BA7F2;">
                    <i class="fas fa-user-plus"></i> Sign Up
                </button>
            </form>

            <!-- Footer -->
            <div class="auth-footer">
                <p style="color: #5a6e84;">Already have an account? <a href="/login" style="color: #7BA7F2; font-weight: 600;">Login</a></p>
            </div>
        </div>
    </div>

    <script>
        function togglePassword(fieldId, btn) {
            const input = document.getElementById(fieldId);
            const icon = btn.querySelector('i');
            
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
            }
        }
    </script>
</body>
</html>